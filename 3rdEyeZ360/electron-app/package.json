{
  "name": "3rdeyez360",
  "version": "1.0.0",
  "description": "3rdEyeZ360 Proctoring Platform",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "cross-env NODE_ENV=development electron ."
  },
  "build": {
    "appId": "com.3rdeyez360.app",
    "productName": "3rdEyeZ360",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "dist-renderer/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "axios": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.8.0",
    "electron-builder": "^26.15.2",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
